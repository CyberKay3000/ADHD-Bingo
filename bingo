  .edit-panel {
    background: #fff; border-radius: 24px 24px 0 0;
    width: 100%; max-width: 540px;
    padding: 26px 20px 40px;
    max-height: 90vh; overflow-y: auto;
    display: flex; flex-direction: column; gap: 14px;
