  { text:'刷牙',           size:'xl', key:false },
];

// 随机任务总池（从中每次随机抽25条，保留关键任务固定位置）
const RANDOM_POOL = [
  { text:'出门走走',       size:'lg', key:false },
  { text:'下楼取快递',     size:'sm', key:false },
  { text:'去便利店',       size:'md', key:false },
  { text:'晒太阳',         size:'lg', key:false },
  { text:'在外面逛逛',     size:'sm', key:false },
  { text:'少刷手机',       size:'md', key:false },
  { text:'背单词',         size:'md', key:false },
  { text:'学一点',         size:'lg', key:false },
  { text:'看教程',         size:'md', key:false },
  { text:'读几页书',       size:'sm', key:false },
  { text:'画张画',         size:'md', key:false },
  { text:'写日记',         size:'md', key:false },
  { text:'整理邮件',       size:'sm', key:false },
  { text:'记账',           size:'xl', key:false },
  { text:'扫地',           size:'xl', key:false },
  { text:'整理桌面',       size:'md', key:false },
  { text:'清理床铺',       size:'md', key:false },
  { text:'扔垃圾',         size:'md', key:false },
  { text:'煮顿饭',         size:'lg', key:false },
  { text:'看剧',           size:'xl', key:false },
  { text:'看电影',         size:'lg', key:false },
  { text:'看纪录片',       size:'md', key:false },
  { text:'听播客',         size:'md', key:false },
  { text:'运动\n15min',    size:'md', key:false },
  { text:'拉伸一下',       size:'md', key:false },
  { text:'深呼吸',         size:'md', key:false },
  { text:'冥想5分钟',      size:'sm', key:false },
  { text:'未久坐\n超过1h', size:'sm', key:false },
  { text:'自控少刷\n信息流', size:'sm', key:false },
  { text:'联系朋友',       size:'md', key:false },
  { text:'回条消息',       size:'md', key:false },
];

// 关键任务（固定出现在随机结果中，保证生存底线）
const KEY_TASKS_FIXED = [
  { text:'好好吃饭',       size:'lg', key:true  },
  { text:'吃早饭',         size:'lg', key:true  },
  { text:'喝够水',         size:'lg', key:true  },
  { text:'吃补剂/药',      size:'md', key:true  },
  { text:'规律睡眠',       size:'lg', key:true  },
  { text:'洗澡',           size:'xl', key:true  },
  { text:'刷牙',           size:'xl', key:false },
];

function shuffle(arr) {
  const a = [...arr];
  for (let i = a.length-1; i > 0; i--) {
    const j = Math.floor(Math.random()*(i+1));
    [a[i],a[j]] = [a[j],a[i]];
  }
  return a;
}

function buildRandomBoard() {
  // 7 key tasks fixed + 18 from random pool
  const extras = shuffle(RANDOM_POOL).slice(0, 18);
  const all = shuffle([...KEY_TASKS_FIXED, ...extras]);
  return all.slice(0, 25);
}

const STORAGE_KEY = 'adhd_bingo_custom_v2';

// ─── State ───────────────────────────────────────────────────────
let tasks = [];
let done = new Set();
let completedLines = new Set();
let totalLines = 0;

const ENCOURAGEMENTS = [
  { emoji:'🎉', title:'太棒了！',   msg:'完成一条连线，继续保持这股劲！' },
  { emoji:'🌟', title:'超级厉害！', msg:'你今天真的很了不起！' },
  { emoji:'🏆', title:'达成连线！', msg:'大脑已上线，状态绝佳！' },
  { emoji:'🚀', title:'冲冲冲！',   msg:'又一条任务线完成，你最棒！' },
  { emoji:'✨', title:'闪耀吧！',   msg:'你正在打败拖延症，加油！' },
];

const CHEERS = ['加油','还不错','继续','很棒','冲！','坚持','厉害','好样的'];

function getDateLabel() {
  const d = new Date();
  const weeks = ['SUN','MON','TUE','WED','THU','FRI','SAT'];
  return `${d.getFullYear()} · ${String(d.getMonth()+1).padStart(2,'0')}/${String(d.getDate()).padStart(2,'0')} · ${weeks[d.getDay()]}`;
}

function loadCustom() {
  try { const r = localStorage.getItem(STORAGE_KEY); if (r) return JSON.parse(r); } catch(e) {}
  return null;
}

function pickTasks(random) {
  if (random) return buildRandomBoard();
  return loadCustom() || [...FIXED_TASKS];
}

// ─── Render ──────────────────────────────────────────────────────
function render() {
  const grid = document.getElementById('grid');
  grid.innerHTML = '';
  tasks.forEach((t, i) => {
    const cell = document.createElement('div');
    cell.className = 'cell' + (done.has(i) ? ' done' : '');
    cell.dataset.size = t.size;
    cell.dataset.key  = t.key ? 'true' : 'false';
    cell.innerHTML = t.text.split('\n')
      .map(l => `<span style="display:block">${l}</span>`).join('');
    cell.onclick = () => toggle(i);
    grid.appendChild(cell);
  });
  updateProgress();
  checkBingo();
}

function toggle(i) {
  done.has(i) ? done.delete(i) : done.add(i);
  render();
}

// ─── Progress ────────────────────────────────────────────────────
function updateProgress() {
  const hasLine = completedLines.size > 0;
  const ringEl = document.getElementById('ring');
  const pctEl  = document.getElementById('pct-label');
  const sub    = document.getElementById('progress-sub');

  if (!hasLine) {
    // No bingo line yet → show raw task count but cap ring at 99%
    const rawPct = Math.min(Math.round(done.size / 5 * 20), 95); // scale to feel meaningful
    ringEl.style.strokeDashoffset = 151 - 151 * rawPct / 100;
    pctEl.textContent = CHEERS[done.size % CHEERS.length];
    pctEl.style.fontSize = '0.52rem';
    if (done.size === 0) sub.textContent = '开始你的今日任务';
    else sub.textContent = `已打卡 ${done.size} 项，连成一线即完成`;
  } else {
    // At least one bingo line → 100% base
    // extra = every done task beyond the cells in the FIRST completed line
    const firstLineCells = new Set();
    getLines().forEach((line, idx) => {
      if (completedLines.has(idx)) line.forEach(i => firstLineCells.add(i));
    });
    // only count the minimal first-line coverage (5 cells), rest are extra
    const extraDone = Math.max(0, done.size - 5);
    ringEl.style.strokeDashoffset = 0;
    if (extraDone > 0) {
      pctEl.textContent = '+' + extraDone;
      pctEl.style.fontSize = '0.7rem';
      sub.textContent = `今日达成！超额完成 ${extraDone} 项 🌟`;
    } else {
      pctEl.textContent = '100%';
      pctEl.style.fontSize = '0.62rem';
      sub.textContent = `完成 ${completedLines.size} 条连线，今日达成！🎉`;
    }
  }
}

function countLineCells() {
  // count unique cells that belong to any completed line
  const covered = new Set();
  getLines().forEach((line, idx) => {
    if (completedLines.has(idx)) line.forEach(i => covered.add(i));
  });
  return covered.size;
}

// ─── Bingo ───────────────────────────────────────────────────────
function getLines() {
  const lines = [];
  for (let r=0;r<5;r++) { const l=[]; for(let c=0;c<5;c++) l.push(r*5+c); lines.push(l); }
  for (let c=0;c<5;c++) { const l=[]; for(let r=0;r<5;r++) l.push(r*5+c); lines.push(l); }
  // diagonals
  lines.push([0,6,12,18,24]);
  lines.push([4,8,12,16,20]);
  return lines;
}

function checkBingo() {
  let newWin = false;
  const cells = document.querySelectorAll('.cell');
  getLines().forEach((line, idx) => {
    if (line.every(i => done.has(i)) && !completedLines.has(idx)) {
      completedLines.add(idx); newWin = true;
      line.forEach(i => {
        cells[i].classList.add('win-line');
        setTimeout(() => cells[i].classList.remove('win-line'), 500);
      });
    }
  });
  totalLines = completedLines.size;
  document.getElementById('lines-label').textContent = `${totalLines} 条连线`;
  if (newWin) { setTimeout(showWin, 420); launchConfetti(); }
}

function showWin() {
  const e = ENCOURAGEMENTS[Math.floor(Math.random()*ENCOURAGEMENTS.length)];
  document.getElementById('win-emoji').textContent = e.emoji;
  document.getElementById('win-title').textContent = e.title;
  document.getElementById('win-msg').textContent   = e.msg;
  document.getElementById('win-toast').classList.add('show');
}
function dismissWin() { document.getElementById('win-toast').classList.remove('show'); }

// ─── Controls ────────────────────────────────────────────────────
function randomize() {
  tasks = pickTasks(true);
  done.clear(); completedLines.clear(); totalLines = 0;
  render();
}
function resetDone() {
  done.clear(); completedLines.clear(); totalLines = 0;
  render();
}

// ─── Edit ────────────────────────────────────────────────────────
function taskToLine(t) {
  let prefix = '';
  if (t.key) prefix += '!';
  if (t.size === 'xl') prefix += '**';
  else if (t.size === 'lg') prefix += '*';
  else if (t.size === 'sm') prefix += '.';
  return prefix + t.text.replace(/\n/g, '/');
}

function lineToTask(line) {
  let s = line.trim();
  let key = false, size = 'md';
  if (s.startsWith('!')) { key = true; s = s.slice(1); }
  if (s.startsWith('**')) { size = 'xl'; s = s.slice(2); }
  else if (s.startsWith('*')) { size = 'lg'; s = s.slice(1); }
  else if (s.startsWith('.')) { size = 'sm'; s = s.slice(1); }
  // auto size by length if no prefix given
  if (size === 'md') {
    const len = s.replace(/\//g,'').length;
    if (len <= 2) size = 'xl';
    else if (len <= 4) size = 'lg';
    else if (len >= 8) size = 'sm';
  }
  return { text: s.replace(/\//g, '\n'), size, key };
}

function openEdit() {
  document.getElementById('edit-textarea').value = tasks.map(taskToLine).join('\n');
  updateCount();
  document.getElementById('edit-overlay').classList.add('open');
}
function closeEdit() { document.getElementById('edit-overlay').classList.remove('open'); }
function overlayClick(e) { if (e.target.id === 'edit-overlay') closeEdit(); }

function updateCount() {
  const lines = document.getElementById('edit-textarea').value
    .split('\n').map(l=>l.trim()).filter(Boolean);
  document.getElementById('edit-count').textContent = `${lines.length} / 25 条`;
  document.getElementById('edit-count').style.color = lines.length === 25 ? '#66bb6a' : '#e57373';
}

function applyEdit() {
  const lines = document.getElementById('edit-textarea').value
    .split('\n').map(l=>l.trim()).filter(Boolean);
  if (lines.length !== 25) { alert(`需要恰好 25 条任务，当前有 ${lines.length} 条`); return; }
  const parsed = lines.map(lineToTask);
  try { localStorage.setItem(STORAGE_KEY, JSON.stringify(parsed)); } catch(e) {}
  tasks = parsed;
  done.clear(); completedLines.clear(); totalLines = 0;
  closeEdit();
  render();
}

// ─── Confetti ────────────────────────────────────────────────────
let confettiFrame;
function launchConfetti() {
  const canvas = document.getElementById('confetti-canvas');
  const ctx = canvas.getContext('2d');
  canvas.width = innerWidth; canvas.height = innerHeight;
  const colors = ['#5c6bc0','#7986cb','#ef5350','#ffa726','#66bb6a','#ab47bc','#26c6da','#ffee58','#ff7043'];

  // Burst from left side and right side simultaneously
  function makePiece(side) {
    const fromLeft = side === 'left';
    const angle = fromLeft
      ? (Math.random() * 70 - 20) * Math.PI / 180   // shoot rightward
      : (Math.PI + (Math.random() * 70 - 20) * Math.PI / 180); // shoot leftward
    const speed = 8 + Math.random() * 14;
    return {
      x: fromLeft ? 0 : canvas.width,
      y: canvas.height * (0.3 + Math.random() * 0.5),
      vx: Math.cos(angle) * speed,
      vy: Math.sin(angle) * speed - 6,
      gravity: 0.35 + Math.random() * 0.2,
      r: 4 + Math.random() * 6,
      color: colors[Math.floor(Math.random() * colors.length)],
      tilt: 0, tiltAngle: 0, tiltSpeed: 0.06 + Math.random() * 0.1,
      shape: Math.random() > 0.4 ? 'rect' : 'circle',
      alpha: 1,
    };
  }

  const pieces = [
    ...Array.from({length:60}, () => makePiece('left')),
    ...Array.from({length:60}, () => makePiece('right')),
  ];

  let elapsed = 0;
  if (confettiFrame) cancelAnimationFrame(confettiFrame);

  function draw() {
    ctx.clearRect(0, 0, canvas.width, canvas.height);
    pieces.forEach(p => {
      p.vx *= 0.98;
      p.vy += p.gravity;
      p.x += p.vx;
      p.y += p.vy;
      p.tiltAngle += p.tiltSpeed;
      p.tilt = Math.sin(p.tiltAngle) * 14;
      if (elapsed > 80) p.alpha = Math.max(0, p.alpha - 0.012);

      ctx.save();
      ctx.globalAlpha = p.alpha;
      ctx.translate(p.x, p.y);
      ctx.rotate(p.tilt * Math.PI / 180);
      ctx.fillStyle = p.color;
      if (p.shape === 'rect') ctx.fillRect(-p.r/2, -p.r/2, p.r * 1.6, p.r * 0.55);
      else { ctx.beginPath(); ctx.arc(0, 0, p.r/2, 0, Math.PI*2); ctx.fill(); }
      ctx.restore();
    });
    elapsed++;
    if (elapsed < 160) confettiFrame = requestAnimationFrame(draw);
    else ctx.clearRect(0, 0, canvas.width, canvas.height);
  }
  draw();
}

// ─── Boot ────────────────────────────────────────────────────────
