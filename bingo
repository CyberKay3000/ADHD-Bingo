  .grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 6px; width: 100%; max-width: 500px;
  }

  .cell {
    background: var(--card-bg);
    border-radius: 10px;
    aspect-ratio: 1;
    display: flex; flex-direction: column;
    align-items: center; justify-content: center;
    text-align: center;
    padding: 4px 3px;
    cursor: pointer;
