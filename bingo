  .cell[data-size="sm"] { font-size: 0.58rem;  font-weight: 400; }

  /* Key tasks: red dot bottom center */
  .cell[data-key="true"]:not(.done)::after {
    content: '';
    position: absolute; bottom: 4px; left: 50%;
    transform: translateX(-50%);
    width: 5px; height: 5px;
    border-radius: 50%;
    background: var(--accent);
